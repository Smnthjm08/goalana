# TXOdds Configuration
TXLINE_ENV="dev" # "dev" or "prod"
TXLINE_API_ORIGIN="https://txline-dev.txodds.com/api/"
TXLINE_JWT="" # Provide your TXOdds JWT
TXLINE_API_TOKEN="" # Provide your TXOdds API Token

# Database
DATABASE_URL="" # Provide your PostgreSQL connection string

# Blockchain
SOLANA_RPC_URL="https://api.devnet.solana.com" # Switch to mainnet RPC for prod
WALLET_PRIVATE_KEY="" # Base58 string or byte array representing wallet private key

# Server Configuration
BE_PORT="8081" # The port your Express backend runs on
API_ONLY="true" # Set to "true" to disable backend cron jobs and background workers

# Production / Deployment URLs
FRONTEND_URL="http://localhost:3000" # URL of the frontend (for CORS and redirects)
NEXT_PUBLIC_API_URL="http://localhost:8081" # URL of the backend (for frontend proxy)