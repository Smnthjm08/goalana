TXLINE_ENV="your-txline_env"
TXLINE_API_ORIGIN="your-txline_api_origin"
TXLINE_JWT="your-txline_jwt"
TXLINE_API_TOKEN="your-txline_api_token"

DATABASE_URL=your-database_url
# uncomment next line if you use Prisma <5.10
# DATABASE_URL_UNPOOLED=your-# database_url_unpooled

BE_PORT="your-be_port"
SOLANA_RPC_URL=your-solana_rpc_url
NEXT_PUBLIC_SOLANA_RPC_URL=your-next_public_solana_rpc_url

HELIUS_RPC_KEY="your-helius_rpc_key"
HELIUS_RPC_URL=your-helius_rpc_url

WALLET_PRIVATE_KEY=your-wallet_private_key

API_ONLY="your-api_only"
# Production / Deployment URLs
FRONTEND_URL="your-frontend_url"
NEXT_PUBLIC_API_URL="your-next_public_api_url"

# Optional — pins the tracked competition instead of auto-discovering one
# (see apps/api/src/config/competition.ts). Defaults to World Cup (72) if unset.
# COMPETITION_ID="72"

# Optional — if set, POST /api/fixtures/sync requires this value in the
# X-Admin-Secret header. Leave unset in local dev; set it in production.
# ADMIN_SYNC_SECRET="your-admin_sync_secret"
