// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  displayName   String?
  totalWagered  BigInt    @default(0)
  totalWon      BigInt    @default(0)
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime?

  // intents Intent[]

  @@map("users")
}

model Fixture {
  fixtureId          BigInt   @id
  ts                 BigInt
  startTime          BigInt
  competition        String
  competitionId      Int
  fixtureGroupId     Int
  participant1Id     Int
  participant1       String
  participant2Id     Int
  participant2       String
  participant1IsHome Boolean
  gameState          Int?
  // Set by scores.processor when the fixture reaches a terminal state.
  // Observed live feeds emit a non-standard StatusId (100) via the
  // undocumented "game_finalised" action rather than the documented 5/10/13 —
  // see scores.processor.ts isTerminalState() for the full condition.
  // Required by settlement.service to call getScoresStatValidation
  finalSeq           Int?
  updatedAt          DateTime @updatedAt

  // ─── Canonical live match state (scores.processor.ts) ───────────────────
  // Derived from the highest-Seq MatchEvent that carries a `Score`/`StatusId`
  // field — never from counting goal events (see scores.processor.ts docs).
  // Null until the first scores event for this fixture has been processed.
  homeScore       Int?
  awayScore       Int?
  liveStatusId    Int?
  // Free-text period label derived from statusId/action (e.g. "H1", "HT",
  // "H2", "FT") — kept as a string because observed values (StatusId=100 /
  // action="game_finalised") fall outside the documented 1–18 enum.
  livePeriodLabel String?
  clockSeconds    Int?
  clockRunning    Boolean?
  // Highest Seq applied to the live state above — used to reject
  // out-of-order/stale deliveries without needing a DB read-then-check race.
  lastEventSeq    Int?
  lastEventTs     BigInt?

  // ─── Proof-integrity evidence (proof-integrity.service.ts) ───────────────
  // Recorded Devnet transactions showing TxLINE's oracle accepting genuine
  // Merkle proofs for several different statistics and rejecting tampered ones.
  // Persisted rather than computed on demand: TxLINE free-tier access ends at
  // the submission deadline, and a recorded tx signature is stronger evidence
  // than a live simulation — it stays independently inspectable on Explorer.
  proofIntegrity Json?

  odds          Odds[]
  matchEvents   MatchEvent[]
  oddsHistories OddsHistory[]
  updates       FixtureUpdate[]
  markets       Market[]

  @@map("fixtures")
}

model FixtureUpdate {
  id String @id @default(cuid())

  fixtureId BigInt
  ts        BigInt

  startTime      BigInt
  competition    String
  competitionId  Int
  fixtureGroupId Int

  participant1Id Int
  participant1   String

  participant2Id Int
  participant2   String

  participant1IsHome Boolean
  gameState          Int?

  payload Json

  createdAt DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@unique([fixtureId, ts])
  @@index([fixtureId])
  @@index([ts])
  @@map("fixture_updates")
}

// ─── Odds (latest market state — one row per market identity) ─────────────────
// Upserted by: odds.processor on every SSE update
// Used for: displaying current odds on frontend

model Odds {
  id            String @id @default(cuid())
  fixtureId     BigInt
  messageId     String
  ts            BigInt
  bookmaker     String
  bookmakerId   Int
  superOddsType String

  marketParameters String   @default("")
  marketPeriod     String   @default("")
  inRunning        Boolean
  gameState        String?
  priceNames       Json
  prices           Json
  probabilities    Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  // Composite unique: one row per market identity
  // marketParameters and marketPeriod use "" not null so PostgreSQL
  // unique constraint works correctly (NULL != NULL in Postgres)
  @@unique([fixtureId, bookmakerId, superOddsType, marketPeriod, marketParameters])
  @@index([fixtureId])
  @@index([superOddsType])
  @@map("odds")
}

// ─── OddsHistory (every update — append only) ─────────────────────────────────
// Inserted by: odds.processor on every SSE update
// Used for: odds movement charts, historical analysis

model OddsHistory {
  id               String   @id @default(cuid())
  fixtureId        BigInt
  // messageId is unique per TxLINE update — use as idempotency key
  messageId        String   @unique
  ts               BigInt
  bookmaker        String
  bookmakerId      Int
  superOddsType    String
  marketParameters String   @default("")
  marketPeriod     String   @default("")
  inRunning        Boolean
  gameState        String?
  priceNames       Json
  prices           Json
  probabilities    Json
  createdAt        DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@index([fixtureId])
  @@index([fixtureId, superOddsType])
  @@index([ts])
  @@map("odds_history")
}

// ─── MatchEvent (score events from SSE stream) ────────────────────────────────
// Inserted/updated by: scores.processor
// Used for: settlement trigger, UI broadcast, audit log

model MatchEvent {
  id        BigInt @id @default(autoincrement())
  fixtureId BigInt
  seq       Int
  action    String
  timestamp BigInt

  // Adding statusId and confirmed as first-class fields
  // because scores.processor queries these repeatedly
  // Option B from feedback — correct choice for this project
  statusId  Int?
  confirmed Boolean?

  payload   Json
  processed Boolean @default(false)

  createdAt DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@unique([fixtureId, seq])
  @@index([fixtureId])
  @@index([fixtureId, action])
  @@index([statusId])
  @@map("match_events")
}

model FixtureBatchValidation {
  id String @id @default(cuid())

  epochDay  Int
  hourOfDay Int

  // Store TxLINE validation response
  validation Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([epochDay, hourOfDay])
  @@map("fixture_batch_validations")
}

model Market {
  id                  String   @id @default(cuid())
  fixtureId           BigInt
  marketPda           String   @unique
  predicateHash       String
  marketType          String
  question            String
  locksAt             DateTime
  settleAfter         DateTime
  creationTx          String?
  sourceOddsMessageId String
  // Nullable: unpriced parametric prop markets (v2-todo item 18) have no
  // TxLINE reference odds to seed from — the pari-mutuel pool is the only
  // price. Every other market type still populates these at creation.
  initialYesPct       Float?
  initialNoPct        Float?
  status              String   @default("OPEN")

  // ─── Lifecycle transition provenance (lock.service / settlement.service) ──
  // Each protocol state change records its on-chain tx + wall-clock time so the
  // UI can render a verifiable Create → Lock → Settle timeline (Explorer link +
  // hash + timestamp per stage). `createdAt` is the create time; `creationTx`
  // above is the create signature; `settlementTx` below is the settle signature.
  lockTx    String?
  lockedAt  DateTime?
  settledAt DateTime?

  // ─── Settlement provenance (settlement.service.ts) ───────────────────────
  // Not retained on-chain past settlement (Market's account only keeps
  // outcome/settledAt) — persisted here so the UI can show what proof was
  // actually used to settle, without re-deriving it.
  settlementTx  String?
  // TxLINE's stat-validation `ts` for the proof that settled this market
  // (ms since epoch) — the timestamp of the underlying stat event itself,
  // not a wall-clock "when we settled" time (that's Market.settledAt).
  oracleTsMs    BigInt?
  // Display-friendly copy of the exact three-stage TxLINE Merkle proof that
  // settled this market (hex-encoded roots/hashes, sibling directions, the
  // anchored daily-roots PDA, resolved outcome). Persisted so the UI can
  // render a verifiable settlement receipt even after TxLINE's free-tier
  // token expires — the on-chain CPI already verified it; this is the record.
  // Shape: see buildSettlementProofRecord() in settlement.service.ts.
  settlementProof Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  // Postgres doesn't auto-index foreign keys — fixtureId is joined on every
  // /api/fixtures/:id request, and status is filtered on every lock/settle
  // cron tick (every minute); both were full-table scans without these.
  @@index([fixtureId])
  @@index([status])
  @@map("markets")
}
