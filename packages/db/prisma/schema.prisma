// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  displayName   String?
  totalWagered  BigInt    @default(0)
  totalWon      BigInt    @default(0)
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime?

  @@map("users")
}

enum Network {
  MAINNET
  DEVNET
}

model Fixture {
  /// TxODDS canonical fixture ID (int64 — stored as BigInt)
  fixtureId          BigInt   @id @map("fixture_id")
  /// Unix timestamp (ms) of when this snapshot was recorded
  ts                 BigInt   @map("ts")
  /// Unix timestamp (ms) of the fixture start time
  startTime          BigInt   @map("start_time")
  competition        String   @map("competition")
  competitionId      Int      @map("competition_id")
  fixtureGroupId     Int      @map("fixture_group_id")
  participant1Id     Int      @map("participant1_id")
  participant1       String   @map("participant1")
  participant2Id     Int      @map("participant2_id")
  participant2       String   @map("participant2")
  participant1IsHome Boolean  @map("participant1_is_home")
  /// Integer game state code (e.g. 1 = scheduled). Not in OpenAPI spec but present in responses.
  gameState          Int?     @map("game_state")
  finalSeq           Int?     @map("final_seq")
  updatedAt          DateTime @updatedAt @map("updated_at")

  odds          Odds[]
  matchEvents   MatchEvent[]
  oddsHistories OddsHistory[]

  @@map("fixtures")
}

model Odds {
  id String @id @default(cuid())

  fixtureId BigInt
  fixture   Fixture @relation(fields: [fixtureId], references: [fixtureId])

  messageId String

  ts BigInt

  bookmaker   String
  bookmakerId Int

  superOddsType String

  marketParameters String?
  marketPeriod     String?

  inRunning Boolean
  gameState String?

  priceNames    Json
  prices        Json
  probabilities Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fixtureId, bookmakerId, superOddsType, marketPeriod, marketParameters])
  @@index([fixtureId])
  @@index([superOddsType])
}

model OddsHistory {
  id String @id @default(cuid())

  fixtureId BigInt
  fixture   Fixture @relation(fields: [fixtureId], references: [fixtureId])

  messageId String @unique
  ts        BigInt

  bookmaker   String
  bookmakerId Int

  superOddsType String

  marketParameters String?
  marketPeriod     String?

  inRunning Boolean
  gameState String?

  priceNames    Json
  prices        Json
  probabilities Json

  createdAt DateTime @default(now())

  @@index([fixtureId])
  @@index([fixtureId, superOddsType])
  @@index([ts])
}

model MatchEvent {
  id BigInt @id @default(autoincrement())

  fixtureId BigInt
  fixture   Fixture @relation(fields: [fixtureId], references: [fixtureId])

  seq Int

  action String

  timestamp BigInt

  payload Json

  processed Boolean @default(false)
  verified  Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([fixtureId, seq])
  @@index([fixtureId])
}
