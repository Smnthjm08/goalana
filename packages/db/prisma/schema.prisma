// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  displayName   String?
  totalWagered  BigInt    @default(0)
  totalWon      BigInt    @default(0)
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime?

  // intents Intent[]

  @@map("users")
}

model Fixture {
  fixtureId          BigInt   @id
  ts                 BigInt
  startTime          BigInt
  competition        String
  competitionId      Int
  fixtureGroupId     Int
  participant1Id     Int
  participant1       String
  participant2Id     Int
  participant2       String
  participant1IsHome Boolean
  gameState          Int?
  // Set by scores.processor when StatusId IN (5, 10, 13)
  // Required by settlement.service to call getScoresStatValidation
  finalSeq           Int?
  updatedAt          DateTime @updatedAt

  odds          Odds[]
  matchEvents   MatchEvent[]
  oddsHistories OddsHistory[]
  updates       FixtureUpdate[]
  // markets       Market[]

  @@map("fixtures")
}

model FixtureUpdate {
  id                 String  @id @default(cuid())

  fixtureId          BigInt
  ts                 BigInt

  startTime          BigInt
  competition        String
  competitionId      Int
  fixtureGroupId     Int

  participant1Id     Int
  participant1       String

  participant2Id     Int
  participant2       String

  participant1IsHome Boolean
  gameState          Int?

  payload            Json

  createdAt          DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@unique([fixtureId, ts])
  @@index([fixtureId])
  @@index([ts])
  @@map("fixture_updates")
}

// ─── Odds (latest market state — one row per market identity) ─────────────────
// Upserted by: odds.processor on every SSE update
// Used for: displaying current odds on frontend

model Odds {
  id            String @id @default(cuid())
  fixtureId     BigInt
  messageId     String
  ts            BigInt
  bookmaker     String
  bookmakerId   Int
  superOddsType String

  marketParameters String   @default("")
  marketPeriod     String   @default("")
  inRunning        Boolean
  gameState        String?
  priceNames       Json
  prices           Json
  probabilities    Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  // Composite unique: one row per market identity
  // marketParameters and marketPeriod use "" not null so PostgreSQL
  // unique constraint works correctly (NULL != NULL in Postgres)
  @@unique([fixtureId, bookmakerId, superOddsType, marketPeriod, marketParameters])
  @@index([fixtureId])
  @@index([superOddsType])
  @@map("odds")
}

// ─── OddsHistory (every update — append only) ─────────────────────────────────
// Inserted by: odds.processor on every SSE update
// Used for: odds movement charts, historical analysis

model OddsHistory {
  id               String   @id @default(cuid())
  fixtureId        BigInt
  // messageId is unique per TxLINE update — use as idempotency key
  messageId        String   @unique
  ts               BigInt
  bookmaker        String
  bookmakerId      Int
  superOddsType    String
  marketParameters String   @default("")
  marketPeriod     String   @default("")
  inRunning        Boolean
  gameState        String?
  priceNames       Json
  prices           Json
  probabilities    Json
  createdAt        DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@index([fixtureId])
  @@index([fixtureId, superOddsType])
  @@index([ts])
  @@map("odds_history")
}

// ─── MatchEvent (score events from SSE stream) ────────────────────────────────
// Inserted/updated by: scores.processor
// Used for: settlement trigger, UI broadcast, audit log

model MatchEvent {
  id        BigInt @id @default(autoincrement())
  fixtureId BigInt
  seq       Int
  action    String
  timestamp BigInt

  // Adding statusId and confirmed as first-class fields
  // because scores.processor queries these repeatedly
  // Option B from feedback — correct choice for this project
  statusId  Int?
  confirmed Boolean?

  payload   Json
  processed Boolean @default(false)

  createdAt DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [fixtureId])

  @@unique([fixtureId, seq])
  @@index([fixtureId])
  @@index([fixtureId, action])
  @@index([statusId])
  @@map("match_events")
}

model FixtureBatchValidation {
  id String @id @default(cuid())

  epochDay  Int
  hourOfDay Int

  // Store TxLINE validation response
  validation Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([epochDay, hourOfDay])
  @@map("fixture_batch_validations")
}
