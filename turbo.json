{
  "$schema": "https://v2-10-3.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "BE_PORT",
        "API_ONLY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_SOLANA_RPC_URL",
        "DATABASE_URL",
        "SOLANA_RPC_URL",
        "WALLET_PRIVATE_KEY",
        "DATABASE_URL_UNPOOLED",
        "TXLINE_API_ORIGIN",
        "TXLINE_JWT",
        "TXLINE_API_TOKEN"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}
