NODE_ENV="your-node_env"
BE_PORT="your-be_port"

# MUST stay "false" on the VM. "true" skips ALL crons + SSE workers
# (index.ts:385) — no market creation, no locking, no settlement.
# apps/api/package.json's `dev:api` script forces API_ONLY=your-# apps/api/package
# boot production through that script.
API_ONLY="your-api_only"

# No trailing slashes. next.config.ts builds the proxy as
# `${NEXT_PUBLIC_API_URL}/api/:path*`, so a trailing slash produces a
# double slash in the rewrite destination.
NEXT_PUBLIC_SITE_URL="your-next_public_site_url"
NEXT_PUBLIC_API_URL="your-next_public_api_url"

# SAME database as local .env (ep-withered-hall) — deliberate, not a copy-paste
# slip. On-chain state is the source of truth and only this DB matches it: it
# holds the 5 France v England markets, all 14 markets, and the two persisted
# proofIntegrity artifacts the Proof Integrity tab renders from. All 7
# migrations are applied here.
#
# The previous value (ep-blue-glitter-ao0xkhj5) was a separate, stale DB —
# 9 markets, 4 migrations behind, no settlementProof/proofIntegrity. Switched
# 2026-07-17. Do not point production back at it: re-recording the
# proof-integrity evidence costs real Devnet txs and TxLINE free-tier access
# ends on the 2026-07-19 deadline.
#
# Consequence to accept: prod and local now share one DB, so local cron runs
# write to the same rows the deployed app serves. Don't run a second
# API_ONLY=your-# api_only
# three concurrent api processes double-processing lifecycle ticks before.
DATABASE_URL=your-database_url

# Backend RPC — goalana.service.ts create/cancel/lock/settle path.
# Was public api.devnet.solana.com; todo.md:39 records that exact value as a
# fixed bug (rate limits + confirmation timeouts). settle_market is a 400k-CU
# tx — do not run it against the public endpoint.
SOLANA_RPC_URL=your-solana_rpc_url

# WAS MISSING — read by apps/web/components/providers/solana-provider.tsx:29.
# Unset falls back to clusterApiUrl(devnet) =your-# unset falls back to clusterapiurl(devnet)
# confirmations surface as false "Bet failed" toasts in a judge's browser.
# NEXT_PUBLIC_* is inlined at BUILD time, so it must be set when the frontend
# is built, not only at runtime.
NEXT_PUBLIC_SOLANA_RPC_URL=your-next_public_solana_rpc_url

# Market authority + keeper. Same wallet as local .env
# (B9cWHC7dS6P1gG98FbXzyYhSMLL8J5dvHfMza39gNPar) — the wallet that created the
# existing Devnet markets, so the only one that can cancel/settle them.
# Do not rotate before France v England settles.
WALLET_PRIVATE_KEY=your-wallet_private_key

TXLINE_ENV="your-txline_env"
TXLINE_API_ORIGIN="your-txline_api_origin"
# JWT expires 2026-08-04T10:15:25Z — safely past the 2026-07-19 deadline.
TXLINE_JWT="your-txline_jwt"
TXLINE_API_TOKEN="your-txline_api_token"

# Optional. competition.ts auto-resolves (keeps World Cup =your-# optional
# upcoming fixture); this is only a manual override. Safe to omit.
# COMPETITION_ID="your-# competition_id"

# Not read anywhere in the codebase (todo.md:39) — SOLANA_RPC_URL and
# NEXT_PUBLIC_SOLANA_RPC_URL above are what's actually consumed. Kept only as a
# record of where the URL came from.
# HELIUS_RPC_KEY="your-# helius_rpc_key"
# HELIUS_RPC_URL=your-# helius_rpc_url
